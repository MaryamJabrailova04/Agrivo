environment  = "dev"
location     = "swedencentral"
project_name = "agrivo"

address_space = ["10.10.0.0/16"]

aks_subnet_address_prefixes = ["10.10.1.0/24"]

private_endpoint_subnet_address_prefixes = ["10.10.2.0/24"]

tags = {
  project     = "agrivo"
  environment = "dev"
  managed_by  = "terraform"
}

kubernetes_version = null
node_vm_size       = "Standard_D2as_v5"
node_count         = 1
min_node_count     = 1
max_node_count     = 2

postgres_admin_username = "agrivoadmin"
postgres_sku_name       = "B_Standard_B1ms"
postgres_storage_mb     = 32768

# tenant_id, admin_object_id, postgres_admin_password, database_url and
# jwt_secret are supplied through TF_VAR_* environment variables in CI/CD.
