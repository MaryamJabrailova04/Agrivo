generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  buyer
  farmer
  logistics
  admin
}

enum ProductStatus {
  active
  draft
  inactive
  out_of_stock
}

enum OrderStatus {
  pending
  accepted
  preparing
  ready
  delivered
  cancelled
}

enum DeliveryStatus {
  assigned
  pickup_scheduled
  ready_for_pickup
  driver_assigned
  pickup_started
  collected
  in_transit
  near_destination
  delivered
  delayed
  cancelled
  issue_reported
}

enum DeliveryPriority {
  low
  normal
  high
}

enum DeliveryMethodType {
  farmer_delivery
  agrivo_logistics
  self_pickup
}

enum FarmerVehicleType {
  motorcycle
  car
  pickup
  truck
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  phone        String?
  role         UserRole
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  farmerProfile    FarmerProfile?
  logisticsProfile LogisticsProfile?
  products         Product[]         @relation("FarmerProducts")
  cartItems        CartItem[]
  buyerOrders      Order[]           @relation("BuyerOrders")
  farmerOrders     Order[]           @relation("FarmerOrders")
  deliveries       Delivery[]        @relation("LogisticsDeliveries")
  couriers         Courier[]         @relation("LogisticsCouriers")
  vehicles         Vehicle[]         @relation("LogisticsVehicles")
}

model FarmerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  farmName        String?
  ownerName       String?
  region          String?
  district        String?
  village         String?
  address         String?
  description     String?
  mainProducts    String?
  mainCategories  String?
  farmSize        String?
  minimumOrder    String?
  deliveryOptions String?
  paymentMethods  String?
  workingDays     String?
  openingTime     String?
  closingTime     String?
  rating          Float    @default(0)
  verified        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliverySettings FarmerDeliverySettings?
  pickupSchedule   PickupSchedule?
}

model LogisticsProfile {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  companyName             String?
  contactPerson           String?
  registrationNumber      String?
  address                 String?
  serviceRegions          String?
  mainRoutes              String?
  driversCount            Int?
  vehiclesCount           Int?
  vehicleTypes            String?
  maxDailyCapacity        String?
  supportedDeliveryTypes    String?
  coldChainSupport        Boolean  @default(false)
  sameDayDelivery         Boolean  @default(false)
  workingDays             String?
  openingTime             String?
  closingTime             String?
  rating                  Float    @default(0)
  verified                Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id          String        @id @default(cuid())
  farmerId    String
  name        String
  category    String
  variety     String?
  description String?
  price       Float
  quantity    Float
  unit        String        @default("kg")
  region      String?
  district    String?
  village     String?
  harvestDate String?
  imageUrl    String?
  status      ProductStatus @default(active)
  isOrganic   Boolean       @default(false)
  isFresh     Boolean       @default(true)
  availableNow Boolean      @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  farmer     User        @relation("FarmerProducts", fields: [farmerId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]
  deliveryOptions ProductDeliveryOptions?
}

model CartItem {
  id        String   @id @default(cuid())
  buyerId   String
  productId String
  quantity  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer   User    @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([buyerId, productId])
}

model Order {
  id              String      @id @default(cuid())
  buyerId         String
  farmerId        String
  status          OrderStatus @default(pending)
  totalAmount     Float
  deliveryMethod  String?
  deliveryFee     Float       @default(0)
  pickupCode      String?
  selectedEtaWindow String?
  deliveryAddress String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  buyer    User        @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  farmer   User        @relation("FarmerOrders", fields: [farmerId], references: [id], onDelete: Cascade)
  items    OrderItem[]
  delivery Delivery?
}

model OrderItem {
  id           String @id @default(cuid())
  orderId      String
  productId    String?
  productName  String
  variety      String?
  quantity     Float
  unit         String
  pricePerUnit Float
  totalPrice   Float

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model Delivery {
  id                 String           @id @default(cuid())
  orderId            String           @unique
  logisticsPartnerId String?
  courierId          String?
  vehicleId          String?
  method             DeliveryMethodType @default(agrivo_logistics)
  driverName         String?
  vehicle            String?
  pickupCode         String?
  pickupLocation     String?
  dropoffLocation    String?
  pickupTime         DateTime?
  eta                DateTime?
  status             DeliveryStatus   @default(assigned)
  priority           DeliveryPriority @default(normal)
  currentLocation    String?
  distanceRemaining  String?
  progress           Int              @default(0)
  completedAt        DateTime?
  proofStatus        String?
  rating             Float?
  feedback           String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  order            Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  logisticsPartner User? @relation("LogisticsDeliveries", fields: [logisticsPartnerId], references: [id], onDelete: SetNull)
  courier          Courier? @relation(fields: [courierId], references: [id], onDelete: SetNull)
  assignedVehicle  Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  trackingEvents   TrackingEvent[]
}

model FarmerDeliverySettings {
  id                     String            @id @default(cuid())
  farmerProfileId        String            @unique
  farmerDeliveryEnabled  Boolean           @default(true)
  deliveryFee            Float             @default(2)
  radiusKm               Float             @default(20)
  workingDays            String            @default("monday,tuesday,wednesday,thursday,friday")
  deliveryHoursStart     String            @default("09:00")
  deliveryHoursEnd       String            @default("19:00")
  maxDailyDeliveries     Int               @default(8)
  vehicleType            FarmerVehicleType @default(pickup)
  logisticsEnabled       Boolean           @default(true)
  logisticsFee           Float             @default(3)
  pickupEnabled          Boolean           @default(true)
  sameDayAvailable       Boolean           @default(true)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  farmerProfile FarmerProfile @relation(fields: [farmerProfileId], references: [id], onDelete: Cascade)
}

model ProductDeliveryOptions {
  id               String  @id @default(cuid())
  productId        String  @unique
  farmerDelivery   Boolean @default(true)
  agrivoLogistics  Boolean @default(true)
  selfPickup       Boolean @default(true)
  farmerFeeOverride Float?
  logisticsFeeOverride Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model PickupSchedule {
  id              String   @id @default(cuid())
  farmerProfileId String   @unique
  address         String?
  hoursStart      String   @default("08:00")
  hoursEnd        String   @default("19:00")
  prepMinutes     Int      @default(25)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  farmerProfile FarmerProfile @relation(fields: [farmerProfileId], references: [id], onDelete: Cascade)
}

model Courier {
  id                 String   @id @default(cuid())
  logisticsPartnerId String
  name               String
  phone              String?
  status             String   @default("available")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  logisticsPartner User       @relation("LogisticsCouriers", fields: [logisticsPartnerId], references: [id], onDelete: Cascade)
  deliveries       Delivery[]
}

model Vehicle {
  id                 String   @id @default(cuid())
  logisticsPartnerId String
  label              String
  plateNumber        String?
  vehicleType        String   @default("van")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  logisticsPartner User       @relation("LogisticsVehicles", fields: [logisticsPartnerId], references: [id], onDelete: Cascade)
  deliveries       Delivery[]
}

model TrackingEvent {
  id         String   @id @default(cuid())
  deliveryId String
  stepId     String
  label      String
  note       String?
  createdAt  DateTime @default(now())

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}
